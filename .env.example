# Supabase (required for auth + sync). Dashboard → Project Settings → API.
# URL: copy "Project URL" (https://YOUR_PROJECT_REF.supabase.co).
# Key: copy "Publishable" key (sb_publishable_...). Matches the dashboard label.
# Legacy: you can still use VITE_SUPABASE_ANON_KEY with the old anon JWT instead.
# Never put Secret / service_role keys in VITE_* or the browser.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

# Optional Sentry browser DSN
# VITE_SENTRY_DSN=

# Optional legacy / other
# GEMINI_API_KEY=
