{
  "entities": {
    "AppState": {
      "title": "AppState",
      "description": "The complete state of the salon management app.",
      "type": "object",
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "budgetCategories": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "openingDate": {
          "type": "string"
        },
        "hammamStatus": {
          "type": "string",
          "enum": ["Ready", "Plumbing", "Tiling", "Foundation"]
        },
        "brandSettings": {
          "type": "object",
          "properties": {
            "palette": {
              "type": "object",
              "properties": {
                "primary": { "type": "string" },
                "secondary": { "type": "string" },
                "accent": { "type": "string" }
              }
            },
            "logoUrl": { "type": "string" },
            "salonName": { "type": "string" }
          }
        }
      },
      "required": ["modules", "budgetCategories", "openingDate", "hammamStatus", "brandSettings"]
    }
  },
  "firestore": {
    "/users/{userId}/data/appState": {
      "schema": "AppState",
      "description": "The user's application state."
    }
  }
}
